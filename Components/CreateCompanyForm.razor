@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@using SmartLeadAI.Models
@using SmartLeadAI.Data
@inject SmartLeadContext DbContext 
@rendermode InteractiveServer

<EditForm Model="@registrationModel" OnValidSubmit="HandleRegistration" FormName="UnifiedRegisterForm">
    <DataAnnotationsValidator/>
    <ValidationSummary/>
    
    <div class="card p-4 shadow-sm">
        <h4 class="text-primary mb-3">Company Information</h4>
        <div class="mb-3">
            <label class="form-label fw-semibold">Company Name</label>
            <InputText @bind-Value="registrationModel.CompanyName" class="form-control" placeholder="Acme Corp" />
            <ValidationMessage For="() => registrationModel.CompanyName" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Company Email</label>
            <InputText @bind-Value="registrationModel.CompanyEmail" class="form-control" placeholder="info@company.com" />
            <ValidationMessage For="() => registrationModel.CompanyEmail" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Company Phone</label>
            <InputText @bind-Value="registrationModel.CompanyPhone" class="form-control" placeholder="+123456789" />
            <ValidationMessage For="() => registrationModel.CompanyPhone" />
        </div>

        <hr class="my-4"/>

        <h4 class="text-primary mb-3">Administrator Account</h4>
        <div class="mb-3">
            <label class="form-label fw-semibold">Your Full Name</label>
            <InputText @bind-Value="registrationModel.AdminName" class="form-control" placeholder="John Doe" />
            <ValidationMessage For="() => registrationModel.AdminName" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Login Email Address</label>
            <InputText @bind-Value="registrationModel.AdminEmail" class="form-control" placeholder="admin@company.com" />
            <ValidationMessage For="() => registrationModel.AdminEmail" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Password</label>
            <InputText type="password" @bind-Value="registrationModel.AdminPassword" class="form-control" placeholder="••••••••" />
            <ValidationMessage For="() => registrationModel.AdminPassword" />
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100 mt-3">Register & Create Account</button>
    </div>
</EditForm>

@code {
    private CompanyRegistrationModel registrationModel = new();

    private async Task HandleRegistration()
    {
        try 
        {
            var newCompany = new Company
            {
                Name = registrationModel.CompanyName,
                Email = registrationModel.CompanyEmail,
                Phone = registrationModel.CompanyPhone,
                CreatedAt = DateTime.UtcNow
            };

            DbContext.Companies.Add(newCompany);
            await DbContext.SaveChangesAsync(); 

            string insertUserSql = @"
                INSERT INTO Users (CompanyId, FullName, Email, PasswordHash, Role, IsActive, CreatedAt)
                VALUES ({0}, {1}, {2}, {3}, {4}, {5}, {6});";

            await DbContext.Database.ExecuteSqlRawAsync(
                insertUserSql, 
                newCompany.Id, 
                registrationModel.AdminName, 
                registrationModel.AdminEmail, 
                registrationModel.AdminPassword, 
                "Admin", 
                true, 
                DateTime.UtcNow
            );

            Console.WriteLine($"Successfully registered company {newCompany.Name} and admin {registrationModel.AdminEmail}");
            
            NavigationManager.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Registration failed: {ex.Message}");
        }
    }

    public class CompanyRegistrationModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Company Name is required")]
        public string CompanyName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Company Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address")]
        public string CompanyEmail { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Company Phone is required")]
        public string CompanyPhone { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Administrator name is required")]
        public string AdminName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Admin Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address")]
        public string AdminEmail { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string AdminPassword { get; set; } = string.Empty;
    }
}