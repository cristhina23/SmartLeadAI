@inject NavigationManager NavigationManager
@inject IDbContextFactory<SmartLeadContext> DbFactory
@using SmartLeadAI.Models
@using SmartLeadAI.Data
@using Microsoft.EntityFrameworkCore
@using SmartLeadAI.Services
@inject GeminiService GeminiService
@inject IJSRuntime JS


<EditForm Model="@currentInteraction" OnValidSubmit="HandleValidSubmit" FormName="CreateInteractionForm">
    <DataAnnotationsValidator/>
    <ValidationSummary class="text-danger mb-3" />
    
    @if (CustomerId == 0)
    {
        <div class="form-group mb-3">
            <label class="form-label required-label">Customer</label>
            <InputSelect @bind-Value="currentInteraction.CustomerId" class="crm-input w-100">
                <option value="0">Select a Customer...</option>
                @foreach (var c in customers)
                {
                    <option value="@c.Id">@c.FullName</option>
                }
            </InputSelect>
            <ValidationMessage For="() => currentInteraction.CustomerId" />
        </div>
    }

    <div class="form-group mb-3">
        <label class="form-label required-label">Assigned User</label>
        <InputSelect @bind-Value="currentInteraction.UserId" class="crm-input w-100">
            <option value="0">Select a User...</option>
            @foreach (var u in users)
            {
                <option value="@u.Id">@u.FullName</option>
            }
        </InputSelect>
        <ValidationMessage For="() => currentInteraction.UserId" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label required-label">Type</label>
        <InputSelect @bind-Value="currentInteraction.Type" class="crm-input w-100">
            <option value="">Select Type...</option>
            <option value="Call">Phone Call</option>
            <option value="Email">Email</option>
            <option value="Meeting">Meeting</option>
            <option value="Note">Internal Note</option>
        </InputSelect>
        <ValidationMessage For="() => currentInteraction.Type" />
    </div>

    <div class="form-group mb-3">
        <label class="form-label required-label">Notes</label>
        <InputTextArea @bind-Value="currentInteraction.Notes" class="crm-input w-100" rows="4" placeholder="What was discussed?" />
        <ValidationMessage For="() => currentInteraction.Notes" />
    </div>

    <div class="mb-4">

    <button type="button"
        class="crm-btn-secondary ai-btn"
        @onclick="ImproveNotes"
        disabled="@isImproving">

        @if (isImproving)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
            <span>Improving Notes...</span>
        }
        else
        {
            <i class="bi bi-stars me-2"></i>
            <span>Improve Notes</span>
        }

    </button>

</div>

<div class="ai-assistant-card">

    <button type="button"
        class="ai-assistant-header"
        @onclick="ToggleAiAssistant">

        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-stars"></i>
            <span>AI Assistant</span>
        </div>

        <i class="bi @(showAiAssistant ? "bi-chevron-up" : "bi-chevron-down")"></i>

    </button>

    @if (showAiAssistant)
    {
        <div class="ai-assistant-body">

            <div class="form-group mb-3">

                <label class="form-label">AI Action</label>

                <InputSelect @bind-Value="selectedAiAction"
                             class="crm-input w-100">

                    <option value="">Select Action...</option>

                    <option value="summary">
                        Generate Summary
                    </option>

                    <option value="response">
                        Suggest Response
                    </option>

                </InputSelect>

            </div>
            @if (!string.IsNullOrWhiteSpace(selectedAiAction))
            {
                <div class="form-group mb-3">

                    <label class="form-label">

                        @(selectedAiAction == "summary"
                            ? "Conversation / Notes"
                            : "Customer Message")

                    </label>

                    <InputTextArea
                        @bind-Value="aiInput"
                        class="crm-input w-100"
                        rows="6"
                        placeholder="Paste your text here..." />

                </div>

                <button type="button"
                    class="crm-btn-primary"
                    @onclick="GenerateAiContent"
                    disabled="@isGeneratingAi">

                    @if (isGeneratingAi)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Generating...</span>
                    }
                    else
                    {
                        <i class="bi bi-stars me-2"></i>
                        <span>Generate</span>
                    }

                </button>

                @if (!string.IsNullOrWhiteSpace(aiResult))
                {
                    <div class="form-group mt-4">

                        <label class="form-label">AI Result</label>

                        <textarea
                            class="crm-input w-100"
                            rows="8"
                            readonly>@aiResult</textarea>

                    </div>

                    <button type="button"
                        class="@(copied ? "btn btn-success" : "crm-btn-secondary")"
                        @onclick="CopyResult">

                    @if (copied)
                    {
                        <i class="bi bi-check-lg me-2"></i>
                        <span>Copied</span>
                    }
                    else
                    {
                        <i class="bi bi-copy me-2"></i>
                        <span>Copy Result</span>
                    }

                </button>
                }
            }



        </div>
    }

</div>

    <div class="form-row mb-3" style="display:flex; gap:1rem;">
        <div class="form-group flex-1" style="flex:1;">
            <label class="form-label required-label">Interaction Date</label>
            <InputDate @bind-Value="currentInteraction.InteractionDate" class="crm-input w-100" />
            <ValidationMessage For="() => currentInteraction.InteractionDate" />
        </div>

        <div class="form-group flex-1" style="flex:1;">
            <label class="form-label">Next Follow Up</label>
            <InputDate @bind-Value="currentInteraction.NextFollowUp" class="crm-input w-100" />
            <ValidationMessage For="() => currentInteraction.NextFollowUp" />
        </div>
    </div>

    <div class="modal-footer px-0 pb-0 mt-4">
        @if (IsRenderedInModal)
        {
            <button type="button" class="crm-btn-secondary" @onclick="OnCancelCallback">Cancel</button>
        }
        <button type="submit" class="crm-btn-primary">Save Interaction</button>
    </div>
</EditForm>

@code {
    // Structural flags matching your original modal constraints
    [Parameter] public int CustomerId { get; set; }
    [Parameter] public int InteractionId { get; set; }
    [Parameter] public bool IsRenderedInModal { get; set; } = false;
    [Parameter] public EventCallback OnSaveCallback { get; set; }
    [Parameter] public EventCallback OnCancelCallback { get; set; }

    private Interaction currentInteraction = new();
    private List<Customer> customers = new();
    private List<User> users = new();

    private bool isImproving = false;

    private bool showAiAssistant = false;

    private string selectedAiAction = "";
    private string aiInput = "";
    private string aiResult = "";
    private bool copied = false;
    private bool isGeneratingAi = false;
    


    private async Task GenerateAiContent()
    {
        isGeneratingAi = true;

        try
        {
            if (selectedAiAction == "summary")
            {
                aiResult =
                    await GeminiService.GenerateSummaryAsync(aiInput);
            }
            else if (selectedAiAction == "response")
            {
                aiResult =
                    await GeminiService.SuggestResponseAsync(aiInput);
            }
        }
        finally
        {
            isGeneratingAi = false;
        }
    }

    private void ToggleAiAssistant()
    {
        showAiAssistant = !showAiAssistant;
    }

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        customers = await context.Customers.AsNoTracking().ToListAsync();
        users = await context.Users.AsNoTracking().ToListAsync();
        
        if (InteractionId > 0)
        {
            var existing = await context.Interactions.FirstOrDefaultAsync(i => i.Id == InteractionId);
            if (existing != null)
            {
                currentInteraction = existing;
            }
        }
        else
        {
            currentInteraction.InteractionDate = DateTime.Now;

            // If we only have one user, default to it
            if (users.Count == 1 && currentInteraction.UserId == 0)
            {
                currentInteraction.UserId = users.First().Id;
            }
        }
    }

  

    private async Task CopyResult()
    {
        await JS.InvokeVoidAsync(
            "navigator.clipboard.writeText",
            aiResult);

        copied = true;

        await InvokeAsync(StateHasChanged);

        await Task.Delay(3000);

        copied = false;

        await InvokeAsync(StateHasChanged);
    }
    private async Task ImproveNotes()
    {
        if (string.IsNullOrWhiteSpace(currentInteraction.Notes))
            return;

        isImproving = true;

        StateHasChanged();

        try
        {
            currentInteraction.Notes =
                await GeminiService.ImproveNotesAsync(currentInteraction.Notes);
        }
        finally
        {
            isImproving = false;
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        if (CustomerId > 0 && InteractionId == 0)
        {
            currentInteraction.CustomerId = CustomerId;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (currentInteraction.CustomerId == 0 || currentInteraction.UserId == 0)
        {
            // Do not submit if CustomerId or UserId is 0
            return;
        }

        using var context = await DbFactory.CreateDbContextAsync();
        
        if (InteractionId > 0)
        {
            context.Interactions.Update(currentInteraction);
        }
        else
        {
            context.Interactions.Add(currentInteraction);
        }
        
        await context.SaveChangesAsync();

        if (IsRenderedInModal)
        {
            // Trigger refresh event callback locally
            await OnSaveCallback.InvokeAsync();
        }
        else
        {
            // Route backwards to list
            NavigationManager.NavigateTo("/interactions");
        }
    }
}

<style>
   .ai-btn{
    display:flex;
    align-items:center;
    gap:.5rem;
    }

    .ai-btn i{
        font-size:1rem;
    }

    .ai-btn:disabled{
        opacity:.75;
        cursor:not-allowed;
    }

    .ai-assistant-card{
    border:1px solid #e5e7eb;
    border-radius:16px;
    overflow:hidden;
    margin-bottom:1.5rem;
    background:white;
    }

    .ai-assistant-header{
        width:100%;
        border:none;
        background:transparent;
        padding:1rem 1.25rem;
        display:flex;
        align-items:center;
        justify-content:space-between;
        cursor:pointer;
        font-weight:600;
    }

    .ai-assistant-body{
        padding:1.25rem;
        border-top:1px solid #f1f5f9;
    }

    .ai-assistant-header:hover{
        background:#f8fafc;
    }
    .copy-success{
    background:#10b981;
    color:white;
    border:none;
    }

    .copy-success:hover{
        background:#059669;
        color:white;
    }
</style>