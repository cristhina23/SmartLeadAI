@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject NavigationManager NavigationManager
@inject AuthService AuthService
@inject IDbContextFactory<SmartLeadContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<EditForm Model="@currentUser" OnValidSubmit="HandleValidSubmit" FormName="CreateUserForm" class="crm-card p-4">
    <DataAnnotationsValidator/>
    <ValidationSummary/>

    <h4 class="mb-3">Add New Team Member</h4>

    <div class="form-floating mb-3">
        <InputText @bind-Value="currentUser.FullName" class="form-control" id="uName" placeholder="Name" />
        <label for="uName">Full Name</label>
        <ValidationMessage For="() => currentUser.FullName" />
    </div>

    <div class="form-floating mb-3">
        <InputText @bind-Value="currentUser.Email" class="form-control" id="uEmail" placeholder="Email" />
        <label for="uEmail">Email Address</label>
        <ValidationMessage For="() => currentUser.Email" />
    </div>

    <div class="form-floating mb-3">
        <InputText type="password" @bind-Value="plainPassword" class="form-control" id="uPass" placeholder="Password" />
        <label for="uPass">Password</label>
    </div>

    <div class="form-floating mb-3">
        <InputSelect @bind-Value="currentUser.Role" class="form-select" id="uRole">
            <option value="Employee">Employee</option>
            <option value="Manager">Manager</option>
            <option value="Agent">Agent</option>
            <option value="Admin">Admin</option>
        </InputSelect>
        <label for="uRole">Role</label>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    <button type="submit" class="crm-btn-primary w-100">Create User</button>
</EditForm>

@code {
    private User currentUser = new();
    private string plainPassword = "";
    private string? errorMessage; // Added to display manual validation errors

    private async Task HandleValidSubmit()
    {
        // 1. MANUAL VALIDATION
        // Here because removed [Required] from PasswordHash in the model. (Prevented creation of user)
        if (string.IsNullOrWhiteSpace(plainPassword) || plainPassword.Length < 8)
        {
            errorMessage = "Password must be at least 8 characters long.";
            return;
        }
        
        errorMessage = null;

        try 
        {
            // 2. Identify the Admin performing the action
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var adminEmail = authState.User.Identity?.Name;

            using var context = await DbFactory.CreateDbContextAsync();
            var adminUser = await context.Users.FirstOrDefaultAsync(u => u.Email.ToLower() == adminEmail.ToLower());

            if (adminUser != null)
            {
                // 3. Assign company and default settings
                currentUser.CompanyId = adminUser.CompanyId;
                currentUser.IsActive = true;
                currentUser.CreatedAt = DateTime.UtcNow;

                // 4. Hash the password before saving
                currentUser.PasswordHash = AuthService.HashPassword(currentUser, plainPassword);

                // 5. Save to database
                context.Users.Add(currentUser);
                await context.SaveChangesAsync();

                // 6. Navigate away upon success
                NavigationManager.NavigateTo("/employees");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating user: {ex.Message}");
            errorMessage = "An unexpected error occurred while creating the user.";
        }
    }
}