@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthStateProvider
@inject SmartLeadAI.Data.SmartLeadContext DbContext

<AuthorizeView>
    <Authorized>
        @* The app-layout class switches based on the isSidebarCollapsed state *@
        <div class="app-layout @(isSidebarCollapsed ? "sidebar-collapsed" : "")">
            
            @* Mobile Backdrop: Only rendered when sidebar is open on mobile *@
            @if (isSidebarCollapsed)
            {
                <div class="sidebar-backdrop" @onclick="ToggleSidebar"></div>
            }

            <aside class="sidebar-container">
                <div class="logo-header">
                    <img src="images/smartlead-logo.png" alt="SmartLead AI" class="brand-logo" />
                </div>
                <div class="sidebar-content">
                    <NavMenu OnNavigate="ToggleSidebar" />
                </div>
            </aside>

            <div class="main-wrapper">
                <header class="top-navbar">
                    <button class="sidebar-toggle" @onclick="ToggleSidebar">
                        <i class="bi bi-list"></i>
                    </button>

                    <div class="search-bar">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" placeholder="Search anything..." class="search-input" />
                    </div>

                    <div class="user-profile">
                        <div class="notification-wrapper">
                            <div class="notification-trigger" @onclick="ToggleNotifications">
                                <i class="bi bi-bell notification-icon"></i>
                                @if (pendingFollowUps > 0)
                                {
                                    <span class="notification-badge">@pendingFollowUps</span>
                                }
                            </div>

                            @if (isNotificationsOpen)
                            {
                                <div class="notification-backdrop" @onclick="CloseNotifications"></div>

                                <div class="notification-dropdown crm-card fade-in" @onclick:stopPropagation="true">
                                    <div class="dropdown-header">
                                        <h6 class="mb-0 fw-bold">Notifications</h6>
                                        @if (pendingFollowUps > 0)
                                        {
                                            <span class="badge bg-danger rounded-pill">@pendingFollowUps New</span>
                                        }
                                    </div>
                                    
                                    <div class="dropdown-body">
                                        @if (pendingFollowUps == 0)
                                        {
                                            <div class="text-center p-3 text-secondary">
                                                <i class="bi bi-check-circle fs-3 d-block mb-2 text-success"></i>
                                                <small>You're all caught up!</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="notification-item">
                                                <div class="icon-circle bg-warning-light text-warning">
                                                    <i class="bi bi-calendar-event"></i>
                                                </div>
                                                <div class="notification-text">
                                                    <p class="mb-0 fw-bold">Follow-ups Due!</p>
                                                    <small class="text-secondary">You have @pendingFollowUps interactions to follow up on today.</small>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="dropdown-footer text-center">
                                        <a href="/interactions" class="text-primary text-decoration-none small" @onclick="CloseNotifications">View all interactions</a>
                                    </div>
                                </div>
                            }
                        </div>
                        <img src="images/avatar.png" alt="Profile" class="avatar" />
                        <div class="user-info">
                            <span class="user-greeting">Welcome, @UserFullName</span>
                            <span class="user-company">@CompanyName</span>
                        </div>
                    </div>
                </header>

                <main class="content-area">
                    @Body
                </main>
            </div>
        </div>
    </Authorized>
    
    <NotAuthorized>
        <main class="public-content-wrapper">
            @Body
        </main>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isSidebarCollapsed = false;
    private bool isNotificationsOpen = false;
    private int pendingFollowUps = 0;
    
    private string UserFullName { get; set; } = "User";
    private string CompanyName { get; set; } = "SmartLead Tenant";

    private void ToggleSidebar() => isSidebarCollapsed = !isSidebarCollapsed;
    
    private void ToggleNotifications() => isNotificationsOpen = !isNotificationsOpen;
    private void CloseNotifications() 
    {
        isNotificationsOpen = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userPrincipal = authState.User;

        if (userPrincipal.Identity?.IsAuthenticated == true)
        {
            var email = userPrincipal.Identity.Name;
            if (!string.IsNullOrEmpty(email))
            {
                try
                {
                    var dbUser = await DbContext.Users
                        .Include(u => u.Company)
                        .FirstOrDefaultAsync(u => u.Email.ToLower() == email.ToLower());

                    if (dbUser != null)
                    {
                        UserFullName = dbUser.FullName;
                        CompanyName = dbUser.Company?.Name ?? "SmartLead AI";

                        var today = DateTime.UtcNow.Date;
                        pendingFollowUps = await DbContext.Interactions
                            .Where(i => i.UserId == dbUser.Id && 
                                        i.NextFollowUp.HasValue && 
                                        i.NextFollowUp.Value.Date <= today)
                            .CountAsync();
                    }
                }
                catch
                {
                    UserFullName = "Admin";
                    CompanyName = "Local Development";
                }
            }
        }
    }
}