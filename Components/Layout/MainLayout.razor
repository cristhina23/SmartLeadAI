@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

@* TODO: Integrate with backend auth *@
    <main>
        <div class="top-row px-4">
            @if (isAuthenticated)
            {
                <span class="user-greeting">Welcome, @userName</span>
                <form method="post" action="/signout">
                    <AntiforgeryToken />
                    <button type="submit" class="btn-primary" style="margin-left: 1rem;">Logout</button>
                </form>
            }
            else
            {
                <span class="user-greeting">Welcome, Guest</span>
                <a href="/loginpage" class="btn-primary" style="margin-left: 1rem; text-decoration: none; display: inline-block;">Login</a>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool isAuthenticated = false;
    private string userName = "User";

    protected override async Task OnParametersSetAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            if (state.User.Identity?.IsAuthenticated == true)
            {
                isAuthenticated = true;
                userName = state.User.Identity.Name ?? "User";
            }
            else
            {
                isAuthenticated = false;
                userName = "User";
            }
        }
    }
}

@* TODO: Extract CSS to external file (if needed) *@
<style>
    /* Phase 1: Layout Scoped CSS */
    .page { display: flex; min-height: 100vh; }
    .sidebar { width: 250px; background-color: var(--clr-navy-dark); color: var(--clr-white); }
    main { flex: 1; display: flex; flex-direction: column; background-color: var(--clr-light); }
    .top-row { height: 60px; background-color: var(--clr-white); display: flex; align-items: center; justify-content: flex-end; border-bottom: 1px solid var(--clr-slate-light); }
    .content { padding: 2rem; }
    .user-greeting { font-weight: 500; color: var(--clr-slate); }
</style>