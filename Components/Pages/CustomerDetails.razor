@page "/customers/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using SmartLeadAI.Models
@using SmartLeadAI.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SmartLeadContext> DbFactory

<PageTitle>Customer Details - Smart Lead AI</PageTitle>

<div class="page-header mt-4 mb-3">
    <div class="breadcrumbs">
        <a href="/customers">Customers</a> <span class="divider">/</span> <span class="active-crumb">Details</span>
    </div>
</div>

@if (customer == null)
{
    <div class="loading-state text-center mt-5">
        <span class="loading-spinner">Loading customer data from database...</span>
    </div>
}
else
{
    <div class="details-container">
        <header class="customer-header crm-card">
            <div class="header-info">
                <h1 class="customer-name">@customer.FullName</h1>
                <span class="crm-badge @GetStatusBadgeClass(customer.Status)">@customer.Status</span>
            </div>
            <div class="header-actions">
                <button class="crm-btn-primary" @onclick="OpenEditCustomerModal">Edit Customer</button>
            </div>
        </header>

        <div class="content-grid">
            <section class="info-section crm-card">
                <h2 class="section-title">Contact Information</h2>
                
                <div class="info-group">
                    <label class="info-label">Email</label>
                    <p class="info-value">@(string.IsNullOrEmpty(customer.Email) ? "—" : customer.Email)</p>
                </div>
                
                <div class="info-group">
                    <label class="info-label">Phone</label>
                    <p class="info-value">@(string.IsNullOrEmpty(customer.Phone) ? "—" : customer.Phone)</p>
                </div>
                
                <div class="info-group">
                    <label class="info-label">Interest Type</label>
                    <p class="info-value">@customer.InterestType</p>
                </div>
                
                <div class="info-group mb-0">
                    <label class="info-label">Notes</label>
                    <p class="info-value notes-text">@(string.IsNullOrEmpty(customer.Notes) ? "No notes logged." : customer.Notes)</p>
                </div>
            </section>

            <section class="interactions-section crm-card">
                <div class="section-header">
                    <h2 class="section-title">Interaction History</h2>
                    <button class="crm-btn-secondary btn-sm" @onclick="OpenInteractionModal">+ Log Interaction</button>
                </div>

                @if (interactions == null || !interactions.Any())
                {
                    <div class="empty-state text-center mt-4">
                        <p>No interactions logged yet. Reach out to get started!</p>
                    </div>
                }
                else
                {
                    <ul class="timeline">
                        @foreach (var interaction in interactions.OrderByDescending(i => i.InteractionDate))
                        {
                            <li class="timeline-item">
                                <div class="timeline-date">@interaction.InteractionDate.ToString("MMM dd, yyyy")</div>
                                <div class="timeline-marker"></div>
                                <div class="timeline-content">
                                    <strong class="interaction-type">@interaction.Type</strong>
                                    <p class="interaction-notes">@interaction.Notes</p>
                                    @if (interaction.NextFollowUp.HasValue)
                                    {
                                        <span class="crm-badge crm-badge-warning follow-up">
                                            Follow up: @interaction.NextFollowUp.Value.ToString("MMM dd, yyyy")
                                        </span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </section>
        </div>
    </div>
}

@* --- MODAL REGISTRATIONS --- *@

@* 1. Edit Customer Modal *@
<EditCustomerModal 
    @bind-IsVisible="isEditCustomerModalVisible" 
    Customer="customer" 
    OnSaveCallback="LoadCustomerDetails" />

@* 2. Log Interaction Modal *@
@if (isInteractionModalVisible)
{
    <div class="modal-backdrop" @onclick="CloseInteractionModal">
        <div class="modal-content crm-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="modal-title">Log Interaction</h2>
                <button class="btn-close" @onclick="CloseInteractionModal">×</button>
            </div>
            <div class="modal-body">
                <CreateInteractionForm 
                    CustomerId="Id" 
                    IsRenderedInModal="true" 
                    OnSaveCallback="async () => { await LoadCustomerDetails(); CloseInteractionModal(); }" 
                    OnCancelCallback="CloseInteractionModal" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Customer? customer;
    private List<Interaction> interactions = new();
    
    private bool isEditCustomerModalVisible = false;
    private bool isInteractionModalVisible = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomerDetails();
    }

    private async Task LoadCustomerDetails()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        customer = await context.Customers
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.Id == Id);

        if (customer != null)
        {
            interactions = await context.Interactions
                .AsNoTracking()
                .Where(i => i.CustomerId == Id)
                .ToListAsync();
        }
    }

    private string GetStatusBadgeClass(string? status)
    {
        return status?.ToLower() switch
        {
            "active" => "crm-badge-success",
            "lead" => "crm-badge-info",
            "closed" => "crm-badge-warning",
            _ => "crm-badge-info"
        };
    }

    private void OpenEditCustomerModal() => isEditCustomerModalVisible = true;
    private void OpenInteractionModal() => isInteractionModalVisible = true;
    private void CloseInteractionModal() => isInteractionModalVisible = false;
}