@page "/customers"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using SmartLeadAI.Models
@using SmartLeadAI.Services
@inject CustomerService CustomerService

<PageTitle>Customers - Smart Lead AI</PageTitle>

@if (customers == null)
{
    <p>Loading customers...</p>
    return;
}

<div class="page-header mt-4 mb-4">
    <h1 class="page-title">Customers</h1>
    @* TODO: Routing - Wire to a new "customers/add" page *@
    <button class="crm-btn-primary">+ Add New Customer</button>
</div>

<div class="search-bar mt-4 mb-4">
    <input type="text" @bind="SearchTerm" @bind:event="oninput" placeholder="Search customers by name or email..." class="crm-input w-100" />
</div>

<div class="crm-card">
    <table class="crm-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Interest Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in FilteredCustomers)
            {
                <tr>
                    <td>@customer.FullName</td>
                    <td>@customer.Email</td>
                    <td>@customer.Phone</td>
                    <td>@customer.InterestType</td>
                    <td>
                        <span class="crm-badge @GetStatusBadgeClass(customer.Status)">
                            @customer.Status
                        </span>
                    </td>
                    <td>
                        <button class="crm-btn-secondary">
                            Details
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<Customer>? customers;
    private string SearchTerm { get; set; } = string.Empty;

    private IEnumerable<Customer> FilteredCustomers =>
        string.IsNullOrWhiteSpace(SearchTerm)
            ? customers ?? new List<Customer>()
            : customers?.Where(c => c.FullName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                                    c.Email.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase))
              ?? new List<Customer>();

    protected override async Task OnInitializedAsync()
    {
        customers = await CustomerService.GetAllAsync();
    }

    private string GetStatusBadgeClass(string status)
    {
        return status?.ToLower() switch
        {
            "active" => "crm-badge-success",
            "lead" => "crm-badge-info",
            "closed" => "crm-badge-warning",
            _ => "crm-badge-info"
        };
    }
}