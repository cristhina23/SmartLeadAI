@page "/customers"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using SmartLeadAI.Models
@using SmartLeadAI.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<SmartLeadContext> DbFactory

<PageTitle>Customers - Smart Lead AI</PageTitle>

<div class="page-header mt-4 mb-4">
    <h1 class="page-title">Customers</h1>
    <a href="/customers/create" class="crm-btn-primary text-decoration-none">+ Add New Customer</a>
</div>

<div class="search-container mt-4 mb-4">
    <input type="text" 
           @bind="SearchTerm" 
           @bind:event="oninput" 
           placeholder="Search customers by name or email..." 
           class="crm-input w-100" />
</div>

<div class="crm-card table-responsive">
    <table class="crm-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Interest Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (customers == null)
            {
                <tr>
                    <td colspan="6" class="text-center empty-state">
                        <span class="loading-spinner">Loading customers from database...</span>
                    </td>
                </tr>
            }
            else if (!FilteredCustomers.Any())
            {
                <tr>
                    <td colspan="6" class="text-center empty-state">No customers found matching your search.</td>
                </tr>
            }
            else
            {
                @foreach (var customer in FilteredCustomers)
                {
                    <tr>
                        <td>@customer.FullName</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.InterestType</td>
                        <td>
                            <span class="crm-badge @GetStatusBadgeClass(customer.Status)">
                                @customer.Status
                            </span>
                        </td>
                        <td>
                            <a href="/customers/@customer.Id" class="crm-btn-secondary text-decoration-none">
                                Details
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    private List<Customer>? customers;
    private string SearchTerm { get; set; } = string.Empty;

    private IEnumerable<Customer> FilteredCustomers =>
        string.IsNullOrWhiteSpace(SearchTerm)
            ? customers ?? new List<Customer>()
            : customers?.Where(c => (c.FullName?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                                    (c.Email?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
              ?? new List<Customer>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;

        if (!string.IsNullOrEmpty(email))
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var currentUser = await context.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Email.ToLower() == email.ToLower());

            if (currentUser != null)
            {
                customers = await context.Customers
                    .AsNoTracking()
                    .Where(c => c.CompanyId == currentUser.CompanyId)
                    .OrderBy(c => c.FullName)
                    .ToListAsync();
            }
        }
    }

    private string GetStatusBadgeClass(string? status)
    {
        return status?.ToLower() switch
        {
            "active" => "crm-badge-success",
            "lead" => "crm-badge-info",
            "closed" => "crm-badge-warning",
            _ => "crm-badge-info"
        };
    }
}