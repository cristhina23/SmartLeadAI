@page "/customers"
@rendermode InteractiveServer

<PageTitle>Customers - Smart Lead AI</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Customers</h1>
    @* TODO: Routing - Wire to a new "customers/add" page *@
    <button class="btn-primary">+ Add New Customer</button>
</div>

<div class="search-bar mt-4 mb-4">
    <input type="text" @bind="SearchTerm" @bind:event="oninput" placeholder="Search customers by name or email..." class="form-control crm-input" />
</div>

<div class="crm-card">
    <table class="crm-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Interest Type</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (customers == null)
            {
                <tr>
                    <td colspan="6" style="text-align: center; padding: 2rem; color: #778DA9;">Loading customers...</td>
                </tr>
            }
            else if (!filteredCustomers.Any())
            {
                <tr>
                    <td colspan="6" style="text-align: center; padding: 2rem; color: #778DA9;">No customers found. Try a different search term.</td>
                </tr>
            }
            else
            {
                @foreach (var customer in filteredCustomers)
                {
                    <tr>
                        <td>@customer.FullName</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.InterestType</td>
                        <td>
                            <span class="badge @GetBadgeClass(customer.Status)">@customer.Status</span>
                        </td>
                        <td>
                            <a href="/customers/@customer.Id" class="btn-primary" style="background-color: var(--clr-slate-light); text-decoration: none; padding: 0.4rem 0.8rem; border-radius: 4px; display: inline-block;">Details</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {    private List<Customer>? customers;
    private string searchTerm = string.Empty;

    private IEnumerable<Customer> filteredCustomers =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? customers ?? Enumerable.Empty<Customer>()
            : customers!.Where(c => c.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                    c.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    public string SearchTerm
    {
        get => searchTerm;
        set => searchTerm = value;
    }

    protected override async Task OnInitializedAsync()
    {
        @* TODO: Backend Integration - Fetch actual data from the database using EF Core 
            Example...
            - customers = await DbContext.Customers.Where(c => c.CompanyId == CurrentCompanyId).ToListAsync(); *@

        @* === MOCK DATA FOR UI TESTING === *@
        await Task.Delay(200); // network latency simulation

        customers = new List<Customer>
        {
            new Customer { Id = 1, CompanyId = 1, FullName = "Blu Berry", Email = "blu.berry@example.com", Phone = "555-1111", InterestType = "Buying", Status = "Active" },
            new Customer { Id = 2, CompanyId = 1, FullName = "Jane Smith", Email = "jane@example.com", Phone = "555-0192", InterestType = "Renting", Status = "Lead" },
            new Customer { Id = 3, CompanyId = 1, FullName = "Robert Ford", Email = "robert.f@example.com", Phone = "555-0205", InterestType = "Buying", Status = "Closed" }
        };
    }

    @* Dynamic badge styling helper method *@
    private string GetBadgeClass(string status)
    {
        return status?.ToLower() switch
        {
            "active" => "badge-active",
            "lead" => "badge-lead",
            "closed" => "badge-closed",
            _ => "badge-inactive" // Default fallback
        };
    }
}

@* TODO: Extract CSS to external file (if needed) *@
<style>
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .crm-input { width: 100%; padding: 0.75rem; border: 1px solid #E0E1DD; border-radius: 4px; }
    .crm-input:focus { outline: none; border-color: #1B263B; box-shadow: 0 0 0 2px rgba(27, 38, 59, 0.1); }
    
    /* Badges */
    .badge { padding: 0.25rem 0.5rem; border-radius: 12px; font-size: 0.85rem; font-weight: 600; }
    .badge-active { background-color: var(--clr-slate, #415A77); color: var(--clr-white, #FFFFFF); }
    .badge-lead { background-color: #778DA9; color: #FFFFFF; }
    .badge-closed { background-color: #E0E1DD; color: #0D1B2A; }
    .badge-inactive { background-color: #f1f1f1; color: #666; }
</style>