@page "/dashboard"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization

@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<SmartLeadContext> DbFactory

<PageTitle>Dashboard - Smart Lead AI</PageTitle>

<div class="dashboard-container mt-4">
    <div class="dashboard-header mb-4">
        <div>
            <h1 class="page-title mb-1">Dashboard</h1>
            <p class="subtitle-text">Welcome back! Here's a summary of your smart lead activities.</p>
        </div>
        <div class="ai-banner-badge">
            <span class="crm-badge crm-badge-info">
                <i class="bi bi-stars me-1"></i> AI Co-Pilot Active
            </span>
        </div>
    </div>

    <div class="stats-grid">
        <div class="crm-card stat-card">
            <div class="stat-icon-wrapper customer-icon-bg">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <h3 class="stat-label">Total Customers</h3>
                <p class="stat-number">@totalCustomersCount</p>
            </div>
        </div>
        <div class="crm-card stat-card">
            <div class="stat-icon-wrapper follow-icon-bg">
                <i class="bi bi-calendar-check-fill"></i>
            </div>
            <div>
                <h3 class="stat-label">Active Follow-ups</h3>
                <p class="stat-number">@activeFollowUpsCount</p>
            </div>
        </div>
        <div class="crm-card stat-card">
            <div class="stat-icon-wrapper recent-icon-bg">
                <i class="bi bi-lightning-charge-fill"></i>
            </div>
            <div>
                <h3 class="stat-label">Recent Interactions</h3>
                <p class="stat-number">@recentInteractionsCount</p>
            </div>
        </div>
    </div>

    <div class="dashboard-sections mt-4">
        <div class="crm-card activity-panel">
            <h2 class="section-title">Recent Activity</h2>
            <div class="activity-feed">
                @if (realActivities == null || !realActivities.Any())
                {
                    <p class="text-muted italic-state">No interactions logged recently.</p>
                }
                else
                {
                    @foreach (var activity in realActivities)
                    {
                        <div class="activity-item">
                            <div class="activity-icon-bullet @GetActivityTypeColor(activity.Type)">
                                <i class="bi @GetActivityIconClass(activity.Type)"></i>
                            </div>
                            <div class="activity-details">
                                <span class="activity-timestamp">@activity.Date.ToString("hh:mm tt")</span>
                                <p class="activity-text">
                                    <strong>@activity.CustomerName</strong>: 
                                    <span class="text-secondary">@activity.Summary</span>
                                </p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="crm-card table-panel">
            <h2 class="section-title">Upcoming Follow-ups</h2>
            <div class="responsive-table-wrapper">
                <table class="crm-table-responsive">
                    <thead>
                        <tr>
                            <th>Customer Name</th>
                            <th>Target Date</th>
                            <th>Channel Type</th>
                            <th class="text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (realFollowUps == null || !realFollowUps.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No upcoming deliverables scheduled.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var followUp in realFollowUps)
                            {
                                <tr>
                                    <td data-label="Customer" class="font-semibold text-main">@followUp.CustomerName</td>
                                    <td data-label="Target Date">@followUp.TargetDate.ToString("MMM dd, yyyy")</td>
                                    <td data-label="Channel">
                                        <span class="channel-pill">
                                            <i class="bi @GetChannelIconClass(followUp.Channel) me-1"></i> @followUp.Channel
                                        </span>
                                    </td>
                                    <td class="action-cell">
                                        <div class="crm-mobile-center">
                                            <a href="/customers/@followUp.CustomerId" class="crm-btn-secondary btn-sm text-decoration-none">
                                                View Profile
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    @@media screen and (max-width: 930px) {
        .crm-table-responsive thead {
            display: none !important;
        }

        .crm-table-responsive tr {
            display: block !important;
            border: 1px solid var(--clr-border) !important;
            border-radius: var(--radius-md) !important;
            background-color: var(--clr-background) !important;
            padding: 0.75rem 1.25rem !important;
            margin-bottom: 1rem !important;
            box-shadow: var(--shadow-sm) !important;
        }

        .crm-table-responsive td {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            padding: 0.6rem 0 !important;
            border-bottom: 1px dashed var(--clr-border) !important;
            width: 100% !important;
            box-sizing: border-box !important;
        }

        .crm-table-responsive td::before {
            content: attr(data-label) !important;
            font-weight: 700 !important;
            color: var(--clr-text-secondary) !important;
            text-transform: uppercase !important;
            font-size: 0.75rem !important;
            letter-spacing: 0.05em !important;
        }

        .crm-table-responsive td.action-cell {
            display: block !important;
            border-bottom: none !important;
            padding-top: 0.85rem !important;
            padding-bottom: 0.25rem !important;
            width: 100% !important;
            text-align: center !important;
        }

        .crm-table-responsive td.action-cell::before {
            content: none !important;
        }

        .crm-mobile-center {
            display: flex !important;
            justify-content: center !important;
            align-items: center !important;
            width: 100% !important;
            text-align: center !important;
        }

        .crm-mobile-center .crm-btn-secondary {
            display: inline-flex !important;
            justify-content: center !important;
            align-items: center !important;
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
            text-align: center !important;
            white-space: nowrap !important;
            padding: 0.5rem 1rem !important;
        }
    }
</style>

@code {
    private int totalCustomersCount = 0;
    private int activeFollowUpsCount = 0;
    private int recentInteractionsCount = 0;

    private List<RecentActivityDto> realActivities = new();
    private List<UpcomingFollowUpDto> realFollowUps = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var email = authState.User.Identity?.Name;

            if (!string.IsNullOrEmpty(email))
            {
                // Create a fresh context instance from the factory
                using var context = await DbFactory.CreateDbContextAsync();
                
                var currentUser = await context.Users
                    .AsNoTracking()
                    .FirstOrDefaultAsync(u => u.Email.ToLower() == email.ToLower());

                if (currentUser != null)
                {
                    var companyId = currentUser.CompanyId;

                    // Securely filter all dashboard metrics by the user's CompanyId
                    totalCustomersCount = await context.Customers
                        .CountAsync(c => c.CompanyId == companyId);
                    
                    recentInteractionsCount = await context.Interactions
                        .CountAsync(i => i.Customer.CompanyId == companyId);
                    
                    activeFollowUpsCount = await context.Interactions
                        .Where(i => i.Customer.CompanyId == companyId && 
                                    i.NextFollowUp != null && 
                                    i.NextFollowUp >= DateTime.Now)
                        .CountAsync();

                    // Fetch real activity data
                    realActivities = await context.Interactions
                        .Include(i => i.Customer)
                        .Where(i => i.Customer.CompanyId == companyId)
                        .OrderByDescending(i => i.InteractionDate)
                        .Take(5)
                        .Select(i => new RecentActivityDto
                        {
                            CustomerName = i.Customer != null ? i.Customer.FullName : "Unknown Customer",
                            Type = i.Type,
                            Summary = i.Notes ?? "No summary notes provided.",
                            Date = i.InteractionDate
                        })
                        .ToListAsync();

                    // Fetch upcoming follow-ups
                    realFollowUps = await context.Interactions
                        .Include(i => i.Customer)
                        .Where(i => i.Customer.CompanyId == companyId && 
                                    i.NextFollowUp != null && 
                                    i.NextFollowUp >= DateTime.Now)
                        .OrderBy(i => i.NextFollowUp)
                        .Take(5)
                        .Select(i => new UpcomingFollowUpDto
                        {
                            CustomerId = i.CustomerId,
                            CustomerName = i.Customer != null ? i.Customer.FullName : "Unknown Customer",
                            TargetDate = i.NextFollowUp ?? DateTime.Now,
                            Channel = i.Type
                        })
                        .ToListAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Dashboard database tracking fault caught: {ex.Message}");
            // Lists remain empty (null/empty state handled in UI)
        }
    }

    // Helper methods for UI icons/styling
    private string GetActivityTypeColor(string type) => type.ToLower() switch
    {
        "call" or "phone" => "icon-primary",
        "email" => "icon-info",
        "whatsapp" => "icon-success",
        _ => "icon-secondary"
    };

    private string GetActivityIconClass(string type) => type.ToLower() switch
    {
        "call" or "phone" => "bi-telephone-outbound-fill",
        "email" => "bi-envelope-paper-fill",
        "whatsapp" => "bi-whatsapp",
        _ => "bi-chat-left-text-fill"
    };

    private string GetChannelIconClass(string channel) => channel.ToLower() switch
    {
        "phone" or "call" => "bi-telephone",
        "email" => "bi-envelope",
        "whatsapp" => "bi-whatsapp",
        _ => "bi-chat"
    };

    private class RecentActivityDto
    {
        public string CustomerName { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public DateTime Date { get; set; }
    }

    private class UpcomingFollowUpDto
    {
        public int CustomerId { get; set; }
        public string CustomerName { get; set; } = string.Empty;
        public DateTime TargetDate { get; set; }
        public string Channel { get; set; } = string.Empty;
    }
}