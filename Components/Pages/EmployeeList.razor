@page "/employees"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using SmartLeadAI.Models

<PageTitle>Employees - Smart Lead AI</PageTitle>

<div class="page-header mt-4 mb-4">
    <h1 class="page-title">Employee Management</h1>
    <button class="crm-btn-primary" @onclick="OpenAddModal">+ Add Employee</button>
</div>

<div class="crm-card table-responsive">
    <table class="crm-table">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (employees == null || !employees.Any())
            {
                <tr>
                    <td colspan="5" class="text-center empty-state">No employees found.</td>
                </tr>
            }
            else
            {
                @foreach (var employee in employees)
                {
                    <tr>
                        <td>@employee.FullName</td>
                        <td>@employee.Email</td>
                        <td>@employee.Role</td>
                        <td>
                            <span class="crm-badge @(employee.IsActive ? "crm-badge-success" : "crm-badge-warning")">
                                @(employee.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="crm-btn-secondary" @onclick="() => OpenEditModal(employee)">Edit</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<EditEmployeeModal @bind-IsVisible="isEditModalVisible" Employee="selectedEmployee" />

@code {
    private bool isEditModalVisible = false;
    private User selectedEmployee = new();
    private List<User> employees = new();

    protected override async Task OnInitializedAsync()
    {
        // === MOCK DATA FOR UI TESTING ===
        await Task.Delay(200); // network latency simulation

        employees = new List<User>
        {
            new User { Id = 1, CompanyId = 1, FullName = "Alex Johnson", Email = "alex@smartlead.com", Role = "Employee", IsActive = true },
            new User { Id = 2, CompanyId = 1, FullName = "Admin User", Email = "admin@smartlead.com", Role = "Admin", IsActive = true },
            new User { Id = 3, CompanyId = 1, FullName = "Elena Rostova", Email = "elena@smartlead.com", Role = "Employee", IsActive = false }
        };
    }

    private void OpenEditModal(User employee)
    {
        selectedEmployee = employee;
        isEditModalVisible = true;
    }

    private void OpenAddModal()
    {
        selectedEmployee = new User(); // Initialize blank model for additions
        isEditModalVisible = true;
    }
}