@using Microsoft.AspNetCore.Authorization;

@page "/employees"
@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin")]
@* Restricts this endpoint solely to Administrative accounts *@

<PageTitle>Employees - Smart Lead AI</PageTitle>

<div class="page-header">
    <h1>Employee Management</h1>
    @* TODO: Routing - Wire to a modal or navigate to employees/add page *@
    <button class="btn-primary">+ Add Employee</button>
</div>

<div class="crm-card mt-4">
    <table class="crm-table">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (employees == null || !employees.Any())
            {
                <tr>
                    <td colspan="5" style="text-align: center; padding: 2rem; color: #778DA9;">No employees found.</td>
                </tr>
            }
            else
            {
                @foreach (var employee in employees)
                {
                    <tr>
                        <td>@employee.FullName</td>
                        <td>@employee.Email</td>
                        <td>@employee.Role</td>
                        <td>
                            <span class="badge @(employee.IsActive ? "badge-active" : "badge-inactive")">
                                @(employee.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="btn-primary" style="background-color: var(--clr-slate-light);" @onclick="() => OpenEditModal(employee)">Edit</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<EditEmployeeModal @bind-IsVisible="isEditModalVisible" />

@code {
    private bool isEditModalVisible = false;
    
    private User selectedEmployee = new();

    private List<User> employees = new();

    protected override async Task OnInitializedAsync()
    {
        @* TODO: Backend Integration - Fetch actual data from the database using EF Core
            Example...
            - employees = await DbContext.Users.Where(u => u.CompanyId == CurrentCompanyId).ToListAsync(); *@

        @* === MOCK DATA FOR UI TESTING === *@
        await Task.Delay(200); // network latency simulation

        employees = new List<User>
        {
            new User { Id = 1, CompanyId = 1, FullName = "Alex Johnson", Email = "alex@smartlead.com", Role = "Employee", IsActive = true },
            new User { Id = 2, CompanyId = 1, FullName = "Admin User", Email = "admin@smartlead.com", Role = "Admin", IsActive = true },
            new User { Id = 3, CompanyId = 1, FullName = "Elena Rostova", Email = "elena@smartlead.com", Role = "Employee", IsActive = false }
        };
    }

    private void OpenEditModal(User employee)
    {
        selectedEmployee = employee;
        isEditModalVisible = true;
        
        @* TODO: Pass 'selectedEmployee' into the EditEmployeeModal as a Parameter with real data *@
    }
}

