@page "/employees"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SmartLeadAI.Models
@using SmartLeadAI.Data 

@inject IDbContextFactory<SmartLeadContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Employees - Smart Lead AI</PageTitle>

<div class="page-header mt-4 mb-4">
    <h1 class="page-title">Employee Management</h1>
    <button class="crm-btn-primary" @onclick="NavigateToCreate">+ Add Employee</button>
</div>

<div class="crm-card table-responsive">
    <table class="crm-table">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (employees == null)
            {
                <tr>
                    <td colspan="5" class="text-center empty-state">
                        <span class="loading-spinner">Loading employees from database...</span>
                    </td>
                </tr>
            }
            else if (!employees.Any())
            {
                <tr>
                    <td colspan="5" class="text-center empty-state">No employees found in the system.</td>
                </tr>
            }
            else
            {
                @foreach (var employee in employees)
                {
                    <tr>
                        <td>@employee.FullName</td>
                        <td>@employee.Email</td>
                        <td>@employee.Role</td>
                        <td>
                            <span class="crm-badge @(employee.IsActive ? "crm-badge-success" : "crm-badge-warning")">
                                @(employee.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="crm-btn-secondary" @onclick="() => OpenEditModal(employee)">Edit</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>


<EditEmployeeModal @bind-IsVisible="isEditModalVisible" Employee="selectedEmployee" OnSaveCallback="ReloadEmployees" />

@code {
    private bool isEditModalVisible = false;
    private User selectedEmployee = new();
    private List<User> employees = null!;

    protected override async Task OnInitializedAsync()
    {
        await ReloadEmployees();
    }

    private async Task ReloadEmployees()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        employees = await context.Users
            .AsNoTracking()
            .OrderBy(u => u.FullName)
            .ToListAsync();
    }

    private void OpenEditModal(User employee)
    {
        selectedEmployee = employee;
        isEditModalVisible = true;
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo("/users/create");
    }
}