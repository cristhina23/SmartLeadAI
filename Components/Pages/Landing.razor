@page "/"
@layout PublicLayout

<PageTitle>SmartLead AI</PageTitle>


<nav class="landing-navbar">

    <div class="navbar-container">

        <img src="images/smartlead-logo.png"
             alt="SmartLead AI"
             class="navbar-logo" />

        <div class="navbar-links">

            <button class="navbar-link">
                Login
            </button>

            <button class="crm-btn-primary">
                Register
            </button>

        </div>

    </div>

</nav>

<section class="hero">

    <div class="hero-content">

        <div class="hero-left">

            <h1>
                Manage Customers,
                Employees and Leads
                with AI
            </h1>

            <p>
                SmartLead AI helps businesses organize customer
                relationships, manage employees, and track
                follow-ups from one powerful platform.
            </p>

            <ul class="features-list">
                <li>
                    <i class="bi bi-people-fill"></i>
                    Customer Management
                </li>

                <li>
                    <i class="bi bi-person-badge-fill"></i>
                    Employee Management
                </li>

                <li>
                    <i class="bi bi-calendar-check-fill"></i>
                    Follow-up Tracking
                </li>

                <li>
                    <i class="bi bi-bar-chart-fill"></i>
                    Business Insights
                </li>
            </ul>

            <div class="hero-buttons">

                <button class="crm-btn-primary">
                    Register Company
                </button>

                <button class="crm-btn-secondary">
                    Login
                </button>

            </div>

        </div>

        <div class="hero-right">

            <img src="images/dashboard.png"
                 alt="Dashboard Preview"
                 class="dashboard-image" />

        </div>

    </div>

</section>

<section class="features-section">

    <div class="features-container">

        <h2>Why SmartLead AI?</h2>

        <p class="section-description">
            Everything you need to manage customers,
            employees, and follow-ups in one place.
        </p>

        <div class="feature-grid">

            <div class="feature-card">

                <i class="bi bi-people-fill"></i>

                <h3>Customer Management</h3>

                <p>
                    Track and organize customer information
                    from a centralized dashboard.
                </p>

            </div>

            <div class="feature-card">

                <i class="bi bi-person-badge-fill"></i>

                <h3>Employee Management</h3>

                <p>
                    Create employees and manage
                    account access with ease.
                </p>

            </div>

            <div class="feature-card">

                <i class="bi bi-calendar-check-fill"></i>

                <h3>Follow-Up Tracking</h3>

                <p>
                    Stay on top of customer interactions
                    and upcoming tasks.
                </p>

            </div>

            <div class="feature-card">

                <i class="bi bi-bar-chart-fill"></i>

                <h3>Business Insights</h3>

                <p>
                    Monitor performance and make
                    better business decisions.
                </p>

            </div>

        </div>

    </div>

</section>

<section class="cta-section">

    <div class="cta-container">

        <h2>Ready to Grow Your Business?</h2>

        <p>
            Start managing customers, employees, and follow-ups
            with SmartLead AI today.
        </p>

        <button class="crm-btn-primary cta-button">
            Register Your Company
        </button>

    </div>

</section>

<footer class="landing-footer">

    <div class="footer-container">

        <img src="images/smartlead-logo.png"
             alt="SmartLead AI"
             class="footer-logo" />

        <p class="footer-text">
            SmartLead AI © 2026
        </p>

        <p class="footer-subtext">
            Customer Management • Employee Management • Follow-Up Tracking
        </p>

    </div>

</footer>