@page "/reports"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using SmartLeadAI.Data

@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<SmartLeadContext> DbFactory
@inject IJSRuntime JS
@inject ExportService ExportService

<PageTitle>Reports - Smart Lead AI</PageTitle>

<div class="page-header mt-4 mb-4 d-flex justify-content-between align-items-center">
    <h1 class="reports-title">Reports</h1>
    <button class="crm-btn-primary" @onclick="ExportReportData">
        <i class="bi bi-download me-2"></i> Export Report
    </button>
</div>

<div class="reports-container">
    @* Stat cards stay the same, but now they will show company-specific data *@
    <div class="report-card customers-card">
        <div class="report-icon"><i class="bi bi-people-fill"></i></div>
        <div>
            <p class="report-label">Total Customers</p>
            <h2>@totalCustomers</h2>
        </div>
    </div>

    <div class="report-card employees-card">
        <div class="report-icon">
            <i class="bi bi-person-badge-fill"></i>
        </div>
        <div>
            <p class="report-label">Total Employees</p>
            <h2>@totalEmployees</h2>
        </div>
    </div>

    <div class="report-card interactions-card">
        <div class="report-icon">
            <i class="bi bi-chat-left-text-fill"></i>
        </div>

        <div>
            <p class="report-label">Total Interactions</p>
            <h2>@totalInteractions</h2>
        </div>
    </div>

    <div class="report-card followups-card">
        <div class="report-icon">
            <i class="bi bi-calendar-check-fill"></i>
        </div>

        <div>
            <p class="report-label">Scheduled Follow-Ups</p>
            <h2>@totalFollowUps</h2>
        </div>
    </div>
</div>

@code {
    private int totalCustomers;
    private int totalEmployees;
    private int totalInteractions;
    private int totalFollowUps;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;

        if (!string.IsNullOrEmpty(email))
        {
            using var context = await DbFactory.CreateDbContextAsync();
            var currentUser = await context.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Email.ToLower() == email.ToLower());

            if (currentUser != null)
            {
                var companyId = currentUser.CompanyId;

                // SECURE QUERIES: Filter all counts by CompanyId
                totalCustomers = await context.Customers.CountAsync(c => c.CompanyId == companyId);
                totalEmployees = await context.Users.CountAsync(u => u.CompanyId == companyId);
                
                // Interactions don't have CompanyId, so we filter through the customer link
                totalInteractions = await context.Interactions.CountAsync(i => i.Customer.CompanyId == companyId);
                totalFollowUps = await context.Interactions.CountAsync(i => i.Customer.CompanyId == companyId && i.NextFollowUp != null);
            }
        }
    }

    private async Task ExportReportData()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.Identity?.Name;
        var currentUser = await context.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Email.ToLower() == email.ToLower());

        if (currentUser != null)
        {
            // 1. Fetch data
            var data = await context.Customers
                .Where(c => c.CompanyId == currentUser.CompanyId)
                .ToListAsync();

            // 2. Generate CSV
            var csvContent = ExportService.GenerateCustomerCsv(data);

            // 3. Trigger download via JS
            var fileName = $"Customers_Report_{DateTime.Now:yyyyMMdd}.csv";
            await JS.InvokeVoidAsync("downloadFile", fileName, csvContent);
        }
    }
}

<style>

    .reports-title {
        font-size: 3rem;
        font-weight: 800;
        color: var(--clr-text);
        margin-bottom: 2rem;
    }

    .reports-container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .report-card {
        background: white;
        border-radius: 20px;
        padding: 2rem;

        display: flex;
        align-items: center;
        gap: 1.5rem;

        border: 1px solid #e5e7eb;

        box-shadow: 0 10px 25px rgba(0,0,0,.05);

        transition: all .3s ease;
    }

    .report-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 18px 35px rgba(0,0,0,.10);
    }

    .report-icon {
        width: 70px;
        height: 70px;

        display: flex;
        align-items: center;
        justify-content: center;

        border-radius: 18px;

        color: white;
        font-size: 1.8rem;

        flex-shrink: 0;
    }

    .customers-card .report-icon {
        background: linear-gradient(135deg, #2563EB, #3B82F6);
    }

    .employees-card .report-icon {
        background: linear-gradient(135deg, #10B981, #34D399);
    }

    .interactions-card .report-icon {
        background: linear-gradient(135deg, #8B5CF6, #A78BFA);
    }

    .followups-card .report-icon {
        background: linear-gradient(135deg, #F59E0B, #FBBF24);
    }

    .report-label {
        margin: 0;
        color: #64748B;
        font-weight: 600;
        font-size: .95rem;
    }

    .report-card h2 {
        margin-top: .35rem;
        margin-bottom: 0;

        font-size: 3rem;
        font-weight: 800;
        color: #0F172A;
    }

    @@media (max-width: 768px) {

        .reports-container {
            grid-template-columns: 1fr;
        }

        .reports-title {
            font-size: 2.2rem;
        }

        .report-card {
            padding: 1.5rem;
        }

        .report-card h2 {
            font-size: 2.5rem;
        }
    }

</style>
