@page "/settings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Settings - Smart Lead AI</PageTitle>

<div class="settings-container">
    <div class="settings-header">
        <h1>Settings</h1>
        <p class="text-secondary">Manage your personal preferences and workspace configurations.</p>
    </div>

    <div class="settings-layout">
        <nav class="settings-sidebar crm-card">
            <ul class="nav-list">
                <li>
                    <button class="nav-btn @(activeTab == "profile" ? "active" : "")" @onclick="@(() => SetActiveTab("profile"))">
                        <i class="icon-user"></i> My Profile
                    </button>
                </li>
                <li>
                    <button class="nav-btn @(activeTab == "preferences" ? "active" : "")" @onclick="@(() => SetActiveTab("preferences"))">
                        <i class="icon-sliders"></i> Preferences
                    </button>
                </li>
                
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <li class="nav-divider">Workspace (Admin)</li>
                        <li>
                            <button class="nav-btn @(activeTab == "company" ? "active" : "")" @onclick="@(() => SetActiveTab("company"))">
                                <i class="icon-briefcase"></i> Company Details
                            </button>
                        </li>
                    </Authorized>
                </AuthorizeView>
            </ul>
        </nav>

        <main class="settings-content crm-card">
            
            @if (activeTab == "profile")
            {
                <div class="tab-pane fade-in">
                    <h2>Profile Information</h2>
                    <hr />
                    <div class="form-group mb-3">
                        <label class="required-label">Full Name</label>
                        <input type="text" class="form-control form-floating" placeholder="Your Name" />
                    </div>
                    <div class="form-group mb-3">
                        <label class="required-label">Email Address</label>
                        <input type="email" class="form-control form-floating" placeholder="name@company.com" disabled />
                        <small class="text-secondary">Contact an administrator to change your email address.</small>
                    </div>
                    <button class="btn btn-primary mt-2">Update Profile</button>
                    
                    <h3 class="mt-5">Security</h3>
                    <hr />
                    <button class="btn btn-outline-danger">Change Password</button>
                </div>
            }

            @if (activeTab == "preferences")
            {
                <div class="tab-pane fade-in">
                    <h2>Application Preferences</h2>
                    <hr />
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="emailNotifications" checked>
                        <label class="form-check-label" for="emailNotifications">Enable Daily Follow-up Reminder Emails</label>
                    </div>
                    <div class="form-group mb-3 mt-4">
                        <label>Default Table View Size</label>
                        <select class="form-control form-floating" style="max-width: 200px;">
                            <option value="10">10 items per page</option>
                            <option value="25">25 items per page</option>
                            <option value="50">50 items per page</option>
                        </select>
                    </div>
                    <button class="btn btn-primary mt-2">Save Preferences</button>
                </div>
            }

            @if (activeTab == "company")
            {
                <div class="tab-pane fade-in">
                    <h2>Company Configurations</h2>
                    <hr />
                    <div class="form-group mb-3">
                        <label class="required-label">Company Name</label>
                        <input type="text" class="form-control form-floating" placeholder="Company Name" />
                    </div>
                    <div class="form-group mb-3">
                        <label>Support Phone</label>
                        <input type="text" class="form-control form-floating" placeholder="(555) 000-0000" />
                    </div>
                    <button class="btn btn-primary mt-2">Save Company</button>

                    <h3 class="mt-5">Data Management</h3>
                    <hr />
                    <button class="btn btn-outline-primary me-2">Export Customers (CSV)</button>
                    <button class="btn btn-outline-secondary">Export Interactions</button>
                </div>
            }

        </main>
    </div>
</div>

@code {
    // Default active tab
    private string activeTab = "profile";

    private void SetActiveTab(string tabName)
    {
        activeTab = tabName;
    }
}