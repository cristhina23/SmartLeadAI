@using SmartLeadAI.Models
@using SmartLeadAI.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SmartLeadContext> DbFactory

@if (IsVisible)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-content crm-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="modal-title">Edit Customer</h2>
                <button class="btn-close" @onclick="CloseModal">×</button>
            </div>
            
            <EditForm Model="Customer" OnValidSubmit="SaveChanges">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">Full Name</label>
                        <InputText @bind-Value="Customer.FullName" class="crm-input w-100" />
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="Customer.Email" class="crm-input w-100" />
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label">Status</label>
                        <InputSelect @bind-Value="Customer.Status" class="crm-input w-100">
                            <option value="Active">Active</option>
                            <option value="Lead">Lead</option>
                            <option value="Closed">Closed</option>
                        </InputSelect>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="crm-btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="crm-btn-primary">Save Changes</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public Customer Customer { get; set; } = new();
    [Parameter] public EventCallback OnSaveCallback { get; set; }

    private async Task CloseModal() { IsVisible = false; await IsVisibleChanged.InvokeAsync(false); }

    private async Task SaveChanges()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        context.Customers.Update(Customer);
        await context.SaveChangesAsync();
        await OnSaveCallback.InvokeAsync();
        await CloseModal();
    }
}