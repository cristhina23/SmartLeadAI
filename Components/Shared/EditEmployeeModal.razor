@using SmartLeadAI.Models
@using SmartLeadAI.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SmartLeadContext> DbFactory

@if (IsVisible)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-content crm-card" @onclick:stopPropagation>
            <div class="modal-header">
                <h2 class="modal-title">Edit Employee</h2>
                <button class="btn-close" @onclick="CloseModal" aria-label="Close">×</button>
            </div>

            <EditForm Model="Employee" OnValidSubmit="SaveChanges">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger mb-3" />

                <div class="modal-body">
                    <div class="form-group mb-3">
                        <label class="form-label">Full Name</label>
                        <InputText @bind-Value="Employee.FullName" class="crm-input w-100" />
                    </div>
                    
                    <div class="form-group mb-3">
                        <label class="form-label">Email</label>
                        <InputText type="email" @bind-Value="Employee.Email" class="crm-input w-100" />
                    </div>

                    <div class="form-row">
                        <div class="form-group flex-1 mb-3">
                            <label class="form-label">Role</label>
                            <InputSelect @bind-Value="Employee.Role" class="crm-input w-100">
                                <option value="Employee">Employee</option>
                                <option value="Admin">Admin</option>
                                <option value="Manager">Manager</option>
                                <option value="Agent">Agent</option>
                            </InputSelect>
                        </div>
                        <div class="form-group flex-1 mb-3">
                            <label class="form-label">Account Status</label>
                            <InputSelect @bind-Value="Employee.IsActive" class="crm-input w-100">
                                <option value="true">Active</option>
                                <option value="false">Deactivated</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="crm-btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="crm-btn-primary">Save Changes</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    [Parameter]
    public User Employee { get; set; } = new();

    [Parameter]
    public EventCallback OnSaveCallback { get; set; }

    private async Task CloseModal()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task SaveChanges()
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            
            context.Users.Update(Employee);
            
            await context.SaveChangesAsync();

            await OnSaveCallback.InvokeAsync();
            
            await CloseModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Database exception while saving employee: {ex.Message}");
        }
    }
}