@if (IsVisible)
{
    <div class="modal-backdrop">
        <div class="modal-content card">
            <div class="modal-header">
                <h2>Edit Employee</h2>
                <button class="btn-close" @onclick="CloseModal" aria-label="Close">×</button>
            </div>

            <div class="modal-body">
                @* TODO: Need to wrap in <EditForm> with DataAnnotationsValidator *@
                
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" @bind="employee.FullName" class="form-control" />
                </div>
                
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" @bind="employee.Email" class="form-control" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Role</label>
                        <select @bind="employee.Role" class="form-control">
                            <option value="Employee">Employee</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="form-group">
                        @* TODO: Fix the selected value not showing properly *@
                        <label>Account Status</label>
                        <select @bind="employee.IsActive" class="form-control">
                            <option value="true">Active</option>
                            <option value="false">Deactivated</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary" @onclick="SaveChanges">Save Changes</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    private User employee = new();

    protected override void OnInitialized()
    {
        @* --- MOCK DATA FOR UI TESTING (Uses real model structure) --- *@
        employee = new User
        {
            Id = 1,
            CompanyId = 1,
            FullName = "Sarah Jenkins",
            Email = "s.jenkins@smartlead.com",
            Role = "Employee",
            IsActive = true
        };
    }

    private async Task CloseModal()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }

    private async Task SaveChanges()
    {
        @* TODO: Implement actual database save logic *@
        Console.WriteLine($"Saved: {employee.FullName}, Role: {employee.Role}, Active: {employee.IsActive}");
        await CloseModal();
    }
}